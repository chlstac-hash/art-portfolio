<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox" onclick="closeLightbox(event)">
  <button class="lightbox-close" onclick="document.getElementById('lightbox').classList.remove('open')">Close ×</button>
  <img src="" alt="" id="lightbox-img">
  <div class="lightbox-caption" id="lightbox-caption"></div>
</div>

<script>
  // Cursor
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursorRing');
  document.addEventListener('mousemove', e => {
    cursor.style.left = e.clientX + 'px';
    cursor.style.top = e.clientY + 'px';
    setTimeout(() => {
      ring.style.left = e.clientX + 'px';
      ring.style.top = e.clientY + 'px';
    }, 60);
  });
  document.querySelectorAll('a,button,.grid-item,.comp-card,.slot,.comp-slot').forEach(el => {
    el.addEventListener('mouseenter', () => {
      cursor.style.width = '18px';
      cursor.style.height = '18px';
      ring.style.width = '54px';
      ring.style.height = '54px';
      ring.style.borderColor = 'rgba(123,47,255,0.5)';
    });
    el.addEventListener('mouseleave', () => {
      cursor.style.width = '10px';
      cursor.style.height = '10px';
      ring.style.width = '36px';
      ring.style.height = '36px';
      ring.style.borderColor = 'rgba(0,229,200,0.4)';
    });
  });

  // Nav
  function showPage(id) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    document.getElementById('nav-' + id).classList.add('active');
    window.scrollTo(0,0);
    return false;
  }
  document.querySelectorAll('nav a').forEach(a => a.addEventListener('click', e => e.preventDefault()));

  // Lightbox
  function openLightbox(src, caption) {
    const lb = document.getElementById('lightbox');
    document.getElementById('lightbox-img').src = src;
    document.getElementById('lightbox-caption').textContent = caption || '';
    lb.classList.add('open');
  }
  function closeLightbox(e) {
    if (e.target === document.getElementById('lightbox')) {
      document.getElementById('lightbox').classList.remove('open');
    }
  }
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') document.getElementById('lightbox').classList.remove('open');
  });

  // Image loading for grid
  function loadImage(input, page) {
    const file = input.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(e) {
      const slot = input.parentElement;
      slot.innerHTML = `<img src="${e.target.result}" alt="Artwork">
        <div class="grid-item-info">
          <div class="grid-item-title">Untitled</div>
          <div class="grid-item-meta">2026</div>
        </div>`;
      slot.classList.remove('slot');
      slot.onclick = () => openLightbox(e.target.result, 'Untitled — 2026');
      // Re-attach cursor listeners
      slot.addEventListener('mouseenter', () => {
        cursor.style.width='18px'; cursor.style.height='18px';
        ring.style.width='54px'; ring.style.height='54px';
      });
      slot.addEventListener('mouseleave', () => {
        cursor.style.width='10px'; cursor.style.height='10px';
        ring.style.width='36px'; ring.style.height='36px';
      });
    };
    reader.readAsDataURL(file);
  }

  // Image loading for competition
  function loadCompImage(input, award, compName) {
    const file = input.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(e) {
      const card = input.parentElement;
      card.innerHTML = `
        <img src="${e.target.result}" alt="Competition work">
        <div class="comp-card-overlay">
          <div class="comp-award">${award}</div>
          <div class="comp-title">${compName}</div>
          <div class="comp-desc">Click to view full image.</div>
        </div>`;
      card.classList.remove('comp-slot');
      card.style.display = '';
      card.onclick = () => openLightbox(e.target.result, award + ' — ' + compName);
    };
    reader.readAsDataURL(file);
  }
</script>
